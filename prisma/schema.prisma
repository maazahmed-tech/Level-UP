generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── User ────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(uuid())
  email                 String    @unique
  passwordHash          String
  firstName             String
  lastName              String
  country               String?
  role                  String    @default("USER")
  plan                  String    @default("FREE")
  planStatus            String    @default("PENDING")
  unitPreference        String    @default("METRIC")
  isActive              Boolean   @default(true)
  paymentScreenshot     String?
  paymentAccountName    String?
  paymentTransactionRef String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  lastLoginAt           DateTime?

  // Health profile fields
  age              Int?
  gender           String?   // male | female
  heightCm         Float?
  currentWeightKg  Float?
  bodyFatPercent    Float?
  fitnessGoal      String?   // fat_loss | muscle_gain | maintenance | recomposition
  activityLevel    String?   // sedentary | light | moderate | active | very_active
  dietaryPrefs     String?   // JSON array
  healthConditions String?   // JSON array
  targetWeightKg   Float?

  // Relations
  weightLogs           WeightLog[]
  progressPhotos       ProgressPhoto[]
  mealLogs             MealLog[]
  macroTarget          UserMacroTarget?
  assets               Asset[]
  favourites           Favourite[]
  restaurantFavourites RestaurantFavourite[]
  sentMessages         Message[]          @relation("SentMessages")
  receivedMessages     Message[]          @relation("ReceivedMessages")
  posts                Post[]
  postLikes            PostLike[]
  postComments         PostComment[]
  stepLogs             StepLog[]
  bodyMeasurements     BodyMeasurement[]
  notifications        Notification[]
  reminders            UserReminder[]
}

// ─── Message ─────────────────────────────────────────────────────────

model Message {
  id         Int      @id @default(autoincrement())
  senderId   String
  receiverId String
  content    String
  imageData  String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, isRead])
}

// ─── Social Feed ─────────────────────────────────────────────────────

model Post {
  id        Int       @id @default(autoincrement())
  authorId  String
  content   String
  mediaType String?
  mediaUrl  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     PostLike[]
  comments  PostComment[]

  @@index([createdAt])
}

model PostLike {
  id     Int    @id @default(autoincrement())
  postId Int
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id        Int      @id @default(autoincrement())
  postId    Int
  userId    String
  content   String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ─── Recipe & Related ────────────────────────────────────────────────

model RecipeCategory {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  recipes      Recipe[]
}

model DietaryTag {
  id      Int                @id @default(autoincrement())
  name    String
  slug    String             @unique
  recipes RecipeDietaryTag[]
}

model Recipe {
  id           Int      @id @default(autoincrement())
  title        String
  slug         String   @unique
  description  String
  categoryId   Int
  ingredients  String
  instructions String
  videoUrl     String?
  imageUrl     String?
  calories     Int
  protein      Float
  carbs        Float
  fat          Float
  servings     Int      @default(1)
  prepTimeMins Int      @default(0)
  cookTimeMins Int      @default(0)
  isPublished  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  category    RecipeCategory     @relation(fields: [categoryId], references: [id])
  dietaryTags RecipeDietaryTag[]
  favourites  Favourite[]

  @@index([categoryId, isPublished])
}

model RecipeDietaryTag {
  recipeId Int
  tagId    Int
  recipe   Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  tag      DietaryTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([recipeId, tagId])
}

// ─── Favourites ──────────────────────────────────────────────────────

model Favourite {
  id       Int    @id @default(autoincrement())
  userId   String
  recipeId Int
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  @@unique([userId, recipeId])
}

model RestaurantFavourite {
  id           Int             @id @default(autoincrement())
  userId       String
  restaurantId Int
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant   RestaurantGuide @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  @@unique([userId, restaurantId])
}

// ─── Testimonial ─────────────────────────────────────────────────────

model Testimonial {
  id           Int      @id @default(autoincrement())
  clientName   String
  duration     String
  quote        String
  category     String   @default("hub")
  profilePhoto String?
  beforePhoto  String?
  afterPhoto   String?
  isFeatured   Boolean  @default(false)
  displayOrder Int      @default(0)
  isPublished  Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Restaurant Guide ────────────────────────────────────────────────

model RestaurantGuide {
  id           Int                   @id @default(autoincrement())
  name         String
  slug         String                @unique
  logoUrl      String?
  introduction String
  tips         String?
  menuItems    String
  isPublished  Boolean               @default(false)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  favourites   RestaurantFavourite[]
}

// ─── Workout Videos ──────────────────────────────────────────────────

model WorkoutCategory {
  id            Int                  @id @default(autoincrement())
  name          String
  slug          String               @unique
  displayOrder  Int                  @default(0)
  subcategories WorkoutSubcategory[]
}

model WorkoutSubcategory {
  id         Int             @id @default(autoincrement())
  name       String
  slug       String          @unique
  categoryId Int
  category   WorkoutCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  workouts   Workout[]
}

model Workout {
  id            Int                @id @default(autoincrement())
  title         String
  slug          String             @unique
  description   String
  videoUrl      String
  instructions  String
  subcategoryId Int
  difficulty    String             @default("Intermediate")
  duration      String?
  targetGoal    String?
  isPublished   Boolean            @default(false)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  subcategory   WorkoutSubcategory @relation(fields: [subcategoryId], references: [id])

  @@index([subcategoryId, isPublished])
}

// ─── Food Database ───────────────────────────────────────────────────

model FoodItem {
  id              Int      @id @default(autoincrement())
  name            String
  category        String   // Proteins, Carbs, Dairy, Vegetables, Fruits, Fats, Grains, Beverages, Snacks, Condiments
  subcategory     String?
  caloriesPer100g Int
  proteinPer100g  Float
  carbsPer100g    Float
  fatPer100g      Float
  fiberPer100g    Float?
  servingSize     Int?     // default serving in grams
  servingUnit     String?  // cup, piece, tbsp, etc.
  isVerified      Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([category])
  @@index([name])
}

// ─── Step Tracker ────────────────────────────────────────────────────

model StepLog {
  id         Int      @id @default(autoincrement())
  userId     String
  steps      Int
  goal       Int      @default(10000)
  loggedDate DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, loggedDate])
  @@index([userId, loggedDate])
}

// ─── Body Measurements ───────────────────────────────────────────────

model BodyMeasurement {
  id          Int      @id @default(autoincrement())
  userId      String
  loggedDate  DateTime
  weightKg    Float?
  bellyInches Float?
  chestInches Float?
  waistInches Float?
  hipsInches  Float?
  armsInches  Float?
  imageData   String?  // progress photo
  notes       String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, loggedDate])
  @@index([userId, loggedDate])
}

// ─── Notifications ───────────────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  userId    String
  title     String
  message   String
  type      String   @default("system") // meal_reminder | admin_alert | system | achievement
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model UserReminder {
  id      Int     @id @default(autoincrement())
  userId  String
  type    String  // breakfast | lunch | dinner | snack | sleep | wakeup
  time    String  // HH:MM format
  enabled Boolean @default(true)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
}

// ─── User Tracking ───────────────────────────────────────────────────

model WeightLog {
  id         Int      @id @default(autoincrement())
  userId     String
  weightKg   Float
  loggedDate DateTime
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, loggedDate])
  @@index([userId, loggedDate])
}

model ProgressPhoto {
  id        Int      @id @default(autoincrement())
  userId    String
  imageData String
  photoDate DateTime
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model MealLog {
  id          Int      @id @default(autoincrement())
  userId      String
  description String
  mealType    String   @default("Snack")
  calories    Int
  protein     Float
  carbs       Float
  fat         Float
  imageData   String?  // meal photo (base64)
  ingredients String?  // JSON: [{foodItemId, name, weightGrams, calories, protein, carbs, fat}]
  loggedDate  DateTime
  loggedTime  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, loggedDate])
}

// ─── Site Content ────────────────────────────────────────────────────

model SiteContent {
  id           Int      @id @default(autoincrement())
  contentKey   String   @unique
  contentValue String
  contentType  String   @default("TEXT")
  updatedAt    DateTime @updatedAt
}

// ─── Asset ───────────────────────────────────────────────────────────

model Asset {
  id           Int      @id @default(autoincrement())
  filename     String
  data         String
  fileSize     Int
  mimeType     String
  altText      String?
  uploadedById String?
  createdAt    DateTime @default(now())
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
}

// ─── User Macro Target ──────────────────────────────────────────────

model UserMacroTarget {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  calories  Int
  protein   Int
  carbs     Int
  fat       Int
  goal      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

// ─── Payment Settings ───────────────────────────────────────────────

model PaymentSettings {
  id            Int     @id @default(autoincrement())
  accountNumber String
  accountName   String
  qrCodeData    String?
  instructions  String?
  price         Int     @default(79)
  currency      String  @default("PKR")
}
